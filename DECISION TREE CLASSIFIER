      "source": [
        "from sklearn.tree import DecisionTreeClassifier\n",
        "\n",
        "X = [\n",
        "    [2, 60],\n",
        "    [4, 70],\n",
        "    [5, 80],\n",
        "    [6, 85],\n",
        "    [8, 90]\n",
        "]\n",
        "\n",
        "y = [\"Fail\", \"Fail\", \"Pass\", \"Pass\", \"Pass\"]\n",
        "\n",
        "model = DecisionTreeClassifier()\n",
        "model.fit(X, y)\n",
        "\n",
        "prediction = model.predict([[6, 75]])\n",
        "\n",
        "print(\"Prediction:\", prediction[0])"
      ],
